{
  "manifest_version": 3,
  "name": "Capsensfaker",
  "version": "2.2.0",
  "description": "Autocomplete forms with Capsens test data norms + AI project generation",
  "permissions": ["activeTab", "scripting", "storage", "identity"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://www.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "453680564168-kobhtlubqsft8gn6dssr7puo7l44q5cb.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  },
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon-16.png",
      "48": "images/icon-48.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["images/startup/*", "images/immobilier/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
